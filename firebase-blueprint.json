        "id": { "type": "string" },
        "category": { "type": "string", "enum": ["rides", "food", "mart", "stays", "intercity"] },
        "platform": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "paymentMethod": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
