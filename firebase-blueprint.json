        "id": { "type": "string" },
        "subject": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "messages": { "type": "array" }
      }
    },
    "SavedAddress": {
      "title": "SavedAddress",
      "description": "User saved address hotspot",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "maxLength": 100 },
        "formattedAddress": { "type": "string", "maxLength": 500 },
        "placeId": { "type": "string", "maxLength": 100 },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      },
      "required": ["name", "formattedAddress", "placeId", "latitude", "longitude"]
    },
    "Branch": {
      "title": "Branch",
      "description": "A branch or business outlet under a partner",
      "type": "object",
      "properties": {
        "branchId": { "type": "string" },
        "branchName": { "type": "string", "maxLength": 100 },
        "branchCode": { "type": "string", "maxLength": 50 },
        "manager": { "type": "string", "maxLength": 100 },
        "phone": { "type": "string", "maxLength": 20 },
        "email": { "type": "string", "maxLength": 100 },
        "address": { "type": "string", "maxLength": 500 },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "openingHours": { "type": "string", "maxLength": 50 },
        "deliveryRadius": { "type": "number" },
        "status": { "type": "string", "enum": ["Open", "Busy", "Temporarily Closed", "Holiday", "Maintenance", "Closing Soon"] }
      },
      "required": ["branchId", "branchName", "branchCode", "status"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Inventory details for a product",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "sku": { "type": "string", "maxLength": 50 },
        "barcode": { "type": "string", "maxLength": 50 },
        "purchasePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "currentStock": { "type": "number" },
        "minimumStock": { "type": "number" },
        "maximumStock": { "type": "number" },
        "supplier": { "type": "string", "maxLength": 100 },
        "expiryDate": { "type": "string" },
        "batchNumber": { "type": "string", "maxLength": 50 },
        "autoStockDeduction": { "type": "boolean" },
        "lowStockAlerts": { "type": "boolean" }
      },
      "required": ["itemId", "currentStock"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Staff member working at a restaurant branch",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "maxLength": 100 },
        "phone": { "type": "string", "maxLength": 20 },
        "role": { "type": "string", "enum": ["Owner", "Branch Manager", "Kitchen Manager", "Chef", "Cashier", "Inventory Manager", "Support", "Delivery Coordinator"] },
        "password": { "type": "string", "maxLength": 100 },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "role", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer feedback and replies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string", "maxLength": 100 },
        "rating": { "type": "number" },
        "comment": { "type": "string", "maxLength": 2000 },
        "reported": { "type": "boolean" },
        "spam": { "type": "boolean" }
      }
    },
    "Coupon": {
      "title": "Coupon",
