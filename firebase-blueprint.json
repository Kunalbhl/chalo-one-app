        "minOrder": { "type": "number" },
        "maxDiscount": { "type": "number" },
        "usageLimit": { "type": "number" },
        "currentUsage": { "type": "number" }
      },
      "required": ["code", "discountType", "discountValue"]
    },
    "Order": {
      "title": "Order",
      "description": "Centralized order lifecycle across food, mart, stays, taxi, pharmacy, hotel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string", "enum": ["food", "mart", "pharmacy", "hotel", "taxi", "stays", "intercity"] },
        "branchId": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string" },
        "amount": { "type": "number" },
        "items": { "type": "array" },
        "driverId": { "type": "string" },
        "etaMins": { "type": "number" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    },
    "OrderEvent": {
      "title": "OrderEvent",
