{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile document containing general details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique user UID" },
        "name": { "type": "string", "maxLength": 100, "description": "Display name of the user" },
        "phone": { "type": "string", "maxLength": 20, "description": "Mobile number" },
        "email": { "type": "string", "maxLength": 100, "description": "Primary email address" },
        "dob": { "type": "string", "maxLength": 20, "description": "Date of birth" },
        "gender": { "type": "string", "maxLength": 20, "description": "Gender identity" },
        "referralCode": { "type": "string", "maxLength": 50, "description": "Unique user referral code" },
        "referredBy": { "type": "string", "maxLength": 50, "description": "Referral code of the user who invited this user" },
        "avatarUrl": { "type": "string", "maxLength": 500, "description": "Download URL of the profile avatar" },
        "role": { "type": "string", "enum": ["super_admin", "affiliate_partner", "user"] }
      },
      "required": ["id", "name", "email", "referralCode"]
    },
    "Wallet": {
      "title": "ChaloWallet",
      "description": "User's digital wallet balances and transaction logs",
      "type": "object",
      "properties": {
        "points": { "type": "number", "description": "Loyalty points balance" },
        "balance": { "type": "number", "description": "Cash wallet balance in INR" },
        "history": { "type": "array", "description": "Array of transaction objects" }
      },
      "required": ["points", "balance"]
    },
    "Referral": {
      "title": "ReferralState",
      "description": "Referral program state and signups tracker",
      "type": "object",
      "properties": {
        "code": { "type": "string", "maxLength": 50, "description": "The user referral code" },
        "pointsEarned": { "type": "number", "description": "Total points earned from referrals" },
        "signupsCount": { "type": "number", "description": "Total successful signups driven" }
      },
      "required": ["code", "pointsEarned", "signupsCount"]
    },
    "AppPreferences": {
      "title": "AppPreferences",
      "description": "User application preferences and security settings",
      "type": "object",
      "properties": {
        "food": { "type": "array", "description": "Preferred food delivery platforms" },
        "mart": { "type": "array", "description": "Preferred quick commerce platforms" },
        "rides": { "type": "array", "description": "Preferred ride platforms" },
        "stays": { "type": "array", "description": "Preferred stay booking platforms" },
        "preferenceMode": { "type": "string", "enum": ["cheapest", "fastest", "rated", "favorites", "ai"] },
        "defaultFoodType": { "type": "string", "enum": ["Veg", "Non-Veg", "Eggetarian", "Doesn't Matter"] },
        "biometricsEnabled": { "type": "boolean" },
        "biometricMode": { "type": "string", "enum": ["fingerprint", "faceid"] },
        "txBiometricsEnabled": { "type": "boolean" },
        "securityPin": { "type": "string", "maxLength": 10, "description": "Secured PIN" }
      },
      "required": ["preferenceMode"]
    },
    "Ride": {
      "title": "Ride",
      "description": "Details of current or past ride bookings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "platform": { "type": "string" },
        "vehicleType": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "eta": { "type": "number" },
        "price": { "type": "number" },
        "status": { "type": "string" },
        "driverName": { "type": "string" },
        "driverPhone": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "otp": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "Details of any other food/stay/mart/intercity booking or order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string", "enum": ["rides", "food", "mart", "stays", "intercity"] },
        "platform": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "paymentMethod": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications document",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "unreadCount": { "type": "number" },
        "list": { "type": "array" }
      }
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Support tickets raised by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "messages": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Public and private details of users"
    },
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "Digital wallet balance and historical credit logs"
    },
    "/referrals/{userId}": {
      "schema": "Referral",
      "description": "Affiliate and direct referral earnings tracking"
    },
    "/preferences/{userId}": {
      "schema": "AppPreferences",
      "description": "Aggregator customization settings"
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Active or past ride records"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "User orders, hotel bookings, quick commerce baskets, or intercity rides"
    },
    "/notifications/{userId}": {
      "schema": "Notification",
      "description": "Real-time user alerts and notification centers"
    },
    "/supportTickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Customer support threads"
    }
  }
}
