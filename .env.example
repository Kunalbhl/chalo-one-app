# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EMAIL_WEBHOOK_API: The API key or URL for the email webhooks service.
EMAIL_WEBHOOK_API="YOUR_EMAIL_WEBHOOK_API"

# EMAIL_API_TOKEN: The secure token for authenticating with the email sending API.
EMAIL_API_TOKEN="YOUR_EMAIL_API_TOKEN"

# SMTP Configuration: Configure these in Settings to enable real email delivery to your inbox (e.g. Gmail, Brevo, Sendgrid, etc.)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME="Chalo One Super-App"

# FIREBASE_DATABASE_SECRET: Secure database secret key for backend Firestore linkage.
FIREBASE_DATABASE_SECRET="FL2BSNMpV0ZAZl8nez9qX7QZX4He1EorXaVI1Fmf"

# CJ_AFFILIATE_EMAIL: Email for Commission Junction Booking.com Affiliate linkage
CJ_AFFILIATE_EMAIL="YOUR_CJ_EMAIL_HERE"

# CJ_AFFILIATE_PASSWORD: Password for Commission Junction Booking.com Affiliate linkage
CJ_AFFILIATE_PASSWORD="YOUR_CJ_PASSWORD_HERE"

# VITE_RECAPTCHA_SITE_KEY: Optional Firebase App Check standard reCAPTCHA v3 site key.
VITE_RECAPTCHA_SITE_KEY=

# VITE_GOOGLE_MAPS_API_KEY: Google Maps API key
VITE_GOOGLE_MAPS_API_KEY=




# SMTP/Email Automation Secrets
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Chalo One" <no-reply@chaloone.com>
ADMIN_EMAIL=
